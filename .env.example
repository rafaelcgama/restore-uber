USERNAME_LINKEDIN=your_linkedin_email@example.com
PASSWORD_LINKEDIN=your_linkedin_password
MAX_TRIES=10
USERNAME_EMAIL=your_gmail@gmail.com
PASSWORD_EMAIL=your_gmail_app_password
DELAY=900
BATCH_SIZE=20
EMAIL_TARGET=360

# ── Proxy rotation ──────────────────────────────────────────────────────────
# Optional: comma-separated private/paid proxies (overrides the free API pool)
# PROXY_LIST=http://1.2.3.4:8080,http://5.6.7.8:3128

# Optional: override the free proxy API source (default: ProxyScrape)
# PROXY_SOURCE_URL=https://api.proxyscrape.com/v2/?request=getproxies&protocol=http&timeout=10000&country=all&ssl=all&anonymity=elite

# ── Chrome for Testing ──────────────────────────────────────────────────────
# Optional: absolute path to a Chrome for Testing binary.
# Download from: https://googlechromelabs.github.io/chrome-for-testing/
# Leave unset to use the system-installed Chrome.
# CHROME_BINARY=/path/to/chrome-for-testing/chrome
