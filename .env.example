USERNAME_LINKEDIN=your_linkedin_email@example.com
PASSWORD_LINKEDIN=your_linkedin_password
MAX_TRIES=10
USERNAME_EMAIL=your_gmail@gmail.com
PASSWORD_EMAIL=your_gmail_app_password
DELAY=900
BATCH_SIZE=20
EMAIL_TARGET=360

# ── Proxy rotation ──────────────────────────────────────────────────────────
# Disabled by default — a residential IP is fine for local / single runs.
# Set to 'false' and configure PROXY_LIST to use a paid proxy service.
DISABLE_PROXY=true

# Optional: comma-separated proxies from a paid service (e.g. Bright Data, Oxylabs).
# When set, these take priority and no free proxy API is ever contacted.
# PROXY_LIST=http://user:pass@proxy.example.com:8080,http://user:pass@proxy.example.com:8081

# ── Chrome for Testing ──────────────────────────────────────────────────────
# Optional: absolute path to a Chrome for Testing binary.
# Download from: https://googlechromelabs.github.io/chrome-for-testing/
# Leave unset to use the system-installed Chrome.
# CHROME_BINARY=/path/to/chrome-for-testing/chrome

# Optional: persist the Chrome session between runs (recommended).
# LinkedIn will only prompt for email verification on the very first run.
# Subsequent runs reuse the saved session cookie — no verification needed.
# CHROME_PROFILE_DIR=/Users/you/.chrome_linkedin_profile
